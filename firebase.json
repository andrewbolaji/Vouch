                }
            },
            "ios": {
                "default": {
                    "projectId": "majorcitymusteats",
                    "appId": "1:400845601317:ios:eca2a15ede7a0691a05dcc",
                    "uploadDebugSymbols": true,
                    "fileOutput": "ios/Runner/GoogleService-Info.plist"
                }
            },
            "macos": {
                "default": {
                    "projectId": "majorcitymusteats",
                    "appId": "1:400845601317:ios:eca2a15ede7a0691a05dcc",
                    "uploadDebugSymbols": true,
                    "fileOutput": "macos/Runner/GoogleService-Info.plist"
                }
            },
            "dart": {
                "lib/firebase_options.dart": {
                    "projectId": "majorcitymusteats",
                    "configurations": {
                        "android": "1:400845601317:android:0a2b01d5e88fb845a05dcc",
                        "ios": "1:400845601317:ios:eca2a15ede7a0691a05dcc",
                        "macos": "1:400845601317:ios:eca2a15ede7a0691a05dcc",
