# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# CocoaPods (generated, large)
ios/Pods/
macos/Pods/

# Firebase config (contains project-specific keys)
lib/firebase_options.dart
.claude/
.agents/

# Node modules (Cloud Functions, test-rules, scripts)
**/node_modules/

# Service account keys and signing credentials (never commit)
**/serviceAccountKey*.json
**/*credentials*.json
**/*sa-*.json
**/*-adminsdk-*.json
*.pem
*.p8
*.key
.env
.env.*

# Portable framework/strategy docs (not Vouch project docs)
/AI_BUILD_FRAMEWORK.md
/AppMarketingPlaybook.md
/BEAUTIFICATION_BRIEF.md
/NEW_PROJECT_SETUP.md
/TEMPLATES_AND_PROTOCOLS.md

# Root-level generated lock files
/macos/Podfile.lock
/package-lock.json
